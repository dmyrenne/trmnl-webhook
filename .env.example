# Visual Crossing Weather API
# Get a free key at: https://www.visualcrossing.com/sign-up
VISUAL_CROSSING_KEY=your_api_key_here
VISUAL_CROSSING_LOCATION=Berlin,DE

# Nextcloud CalDAV
# URL format: https://your-nextcloud.example.com/remote.php/dav
CALDAV_URL=https://nextcloud.example.com/remote.php/dav
CALDAV_USER=username
CALDAV_PASSWORD=password
# (optional) Calendar display name as shown in Nextcloud, e.g. "Personal". If not set or found, all calendars will be loaded.
CALDAV_CALENDAR_NAME=personal

# LaraPaper Image Webhook URL
# Found in your LaraPaper plugin settings
LARAPAPER_WEBHOOK_URL=http://your-larapaper-host/api/plugin_settings/YOUR-PLUGIN-UUID/image

# Custom font (optional)
# Place font files in ./fonts/ and set the CSS font-family name here
# If left empty, Caveat (Google Fonts) is used as a handwriting fallback
CUSTOM_FONT_FAMILY=

# Update schedule (default: 15M)
# Formats:
#   15M   → every 15 minutes
#   2H    → every 2 hours
#   15:00 → once a day at 15:00
UPDATE_SCHEDULE=15M

# Timezone for date and time
# List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Berlin

# Language & date format (country code or BCP-47 locale)
# Affects: date/time format, calendar labels, weather text
# Short codes: DE, US, GB, FR, ES, IT, NL, PT, BR, AT, CH, SE, NO, DK, FI, PL, ...
# Or full BCP-47: de-DE, en-US, fr-FR, ...
LOCALE=US

# Time format: 12h or 24h (default: 12h for US, 24h for all others)
TIME_FORMAT=

# Temperature unit: C or F (default: F for US, C for all others)
UNIT_TEMP=

# Server port (internal container port — do not change when using Docker)
PORT=3000
