# Visual Crossing Wetter API
# Kostenlosen Key beantragen: https://www.visualcrossing.com/sign-up
VISUAL_CROSSING_KEY=your_api_key_here
VISUAL_CROSSING_LOCATION=Berlin,DE

# Nextcloud CalDAV
# URL-Format: https://your-nextcloud.example.com/remote.php/dav
CALDAV_URL=https://nextcloud.example.com/remote.php/dav
CALDAV_USER=username
CALDAV_PASSWORD=password
# Anzeigename des Kalenders (sichtbar in Nextcloud, z.B. "Persönlich")
CALDAV_CALENDAR_NAME=personal

# LaraPaper Image Webhook URL
# Zu finden in der LaraPaper Plugin-Konfiguration
LARAPAPER_WEBHOOK_URL=http://your-larapaper-host/api/plugin_settings/YOUR-PLUGIN-UUID/image

# Eigene Schriftart (optional)
# Font-Dateien in ./fonts/ ablegen, hier den gewünschten CSS-Namen angeben
# Ohne Angabe wird Caveat (Google Fonts) als Handschrift-Fallback verwendet
CUSTOM_FONT_FAMILY=

# Update-Zeitplan (Standard: 15M)
# Formate:
#   15M   → alle 15 Minuten
#   2H    → alle 2 Stunden
#   15:00 → täglich um 15:00 Uhr
UPDATE_SCHEDULE=15M

# Zeitzone für Datum/Uhrzeit
# Liste: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Berlin

# Server-Port (intern im Container, nicht ändern wenn docker-compose genutzt wird)
PORT=3000
